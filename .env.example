# Copy this file to ".env" and fill in the values from your WHOOP developer app.
#
# How to get these (one-time, ~5 min):
#   1. Go to https://developer.whoop.com and sign in with your WHOOP account.
#   2. Create a Team, then create a new App.
#   3. Set the Redirect URI to EXACTLY:  http://localhost:8755/callback
#   4. Select scopes: read:recovery read:sleep read:workout read:cycles read:profile read:body_measurement offline
#   5. Copy the Client ID and Client Secret into the values below.

WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# Must match the Redirect URI registered in the WHOOP developer portal.
WHOOP_REDIRECT_URI=http://localhost:8755/callback

# Local dashboard port (open http://localhost:8756 in your browser).
DASHBOARD_PORT=8756

# --- Phone access (optional) ----------------------------------------------
# By default the dashboard binds to 127.0.0.1 (Mac only). To reach it from your
# phone, set the host to 0.0.0.0 and connect over Tailscale (recommended) or your
# local Wi-Fi. See the "See it on your phone" section of the README.
# DASHBOARD_HOST=0.0.0.0
#
# Shared secret required for phone (non-localhost) requests. Optional over a private
# Tailscale tailnet; set it if you bind to 0.0.0.0 on shared Wi-Fi. Then open the
# dashboard once as  http://<host>:8756/?token=YOUR_SECRET  (a cookie remembers it).
# DASHBOARD_TOKEN=

# --- Calorie tracking (optional) ------------------------------------------
# Free Nutritionix key lets you log food in plain English ("2 eggs and toast") and
# auto-fill calories + macros. Get one at https://www.nutritionix.com/business/api
# Without it, manual calorie entry still works.
# NUTRITIONIX_APP_ID=your_app_id
# NUTRITIONIX_APP_KEY=your_app_key
